BYTE_PUA_BASE = 0x10FFE00
BYTE_PUA_LAST = BYTE_PUA_BASE + 0xFF

def encode_byte_to_u10ffe str
	bytes = String(str).b.bytes
	bytes.map { |value| [BYTE_PUA_BASE + value].pack("U") }.join
end

def decode_byte_from_u10ffe str
	encoded = String(str)
	decoded_bytes = encoded.each_codepoint.map do |cp|
		raise ArgumentError, "char out of range: U+#{cp.to_s(16).upcase}" if cp < BYTE_PUA_BASE || cp > BYTE_PUA_LAST
		cp - BYTE_PUA_BASE
	end
	decoded_bytes.pack("C*").force_encoding(Encoding::BINARY)
end

def snake_to_camel str, lower: false
	parts = String(str).split('_').reject(&:empty?)
	camel = parts.map { |part| part[0] ? part[0].upcase + part[1..].to_s.downcase : "" }.join
	lower ? camel.sub(/\A[A-Z]/) { |c| c.downcase } : camel
end

def camel_to_snake str
	String(str)
		.gsub(/::/, '/')
		.gsub(/([A-Z]+)([A-Z][a-z])/, '\\1_\\2')
		.gsub(/([a-z\d])([A-Z])/, '\\1_\\2')
		.tr('-', '_')
		.downcase
end

class IdentPath
	List = {}
	attr_reader :path, :real_dev, :real_inode, :real_ctime, :id
	def initialize path
		@path = File.expand_path path
		@real_dev, @real_inode, @real_ctime = self.class.getRealInfo @path
		key = [@path, @real_dev, @real_inode, @real_ctime]
		if List.key? key
			yield List[key]
		else
			List[key] = self
			@id = List.size
			yield self
		end
	end
	def norm
		key = [@path, @real_dev, @real_inode, @real_ctime]
		if List.key? key
			return List[key]
		else
			List[key] = self
			@id = List.size
			return self
		end
	end
	def self.emerge path
		if path.is_a? IdentPath
			return path.norm
		else
			new path do |emerged|
				return emerged
			end
		end
	end
	def self.getRealInfo path
		real = File.realpath(File.expand_path(path)) rescue nil
		if real
			realStat = File.stat(real) rescue nil
			if realStat
				return realStat.dev, realStat.ino, realStat.ctime
			end
		end
		return nil, nil, nil
	end
	def status_msg
		return case
		when !File.exist?(@path)
			"Directory, '#{@path}' not found"
		when self.class.getRealInfo(@path) != [@real_dev, @real_inode, @real_ctime]
			"Directory, '#{@path}' has been recreated since last execution of the command"
		else
			""
		end
	end
	def to_s
		return @id.to_s + @path
	end
	def self.[] id
		List[id.to_i - 1]
	end
	def == other
		self.to_s == other.to_s
	end
end

def encode_mdata id_path, sid
	marr = [id_path, sid]
	mdumped = Marshal.dump marr
	encoded = encode_byte_to_u10ffe mdumped
	"#{MDATA_START}#{encoded}"
end

def decode_mdata buff
	if buff.start_with? MDATA_START
		encoded = buff[MDATA_START.size..-1]
		mdumped = decode_byte_from_u10ffe encoded
		marr = Marshal.load mdumped
		marr[0] = marr[0].norm # normalize the IdentPath object
		return marr[0].norm, marr[1]
	end
	return nil, nil
end

