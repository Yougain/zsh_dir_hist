BindKeyData = {}

def do_initialize_bindkey_data bindkey_path
	bindkey_path = File.expand_path(bindkey_path)
	if File.exist? bindkey_path
		File.open bindkey_path do |f|
			f.each_line do |line|
				if line =~ /^\s*"(.*?)"\s+"(.*?)"/
					keyseq = $1
					widget = $2
					BindKeyData[keyseq] = widget
					(BindKeyData[widget] ||= []).push keyseq
				end
			end
		end
	else
		STDERR.puts "Warning: bindkey data file '#{bindkey_path}' not found. Bind key sequence for alt key combinations will not be available."
	end
end

def do_get_bind_keyseq_for widget
	BindKeyData[widget].join(" ") || ""
end

class Key
	List = {}
	attr_reader :seq
	require 'set'
	def initialize nameSet, seq
		@nameSet = nameSet
		@seq = seq
		List[@nameSet] = self
		(List[seq] ||= []).push self
	end
	def self.emerge name: nil, seq: nil
		if name
			nameSet = Set.new *name.split("-").map{_1.downcase}
			if seq
				if List[nameSet]
					raise ArgumentError, "Inconsistent key data: name '#{name}' and sequence '#{seq}' correspond to different keys."
				end
				return List[nameSet] = new(nameSet, seq)
			end
			if List.key?(nameSet)
				return List[nameSet]
			else
				return nil
			end
		end
		if seq
			return List[seq]
		end
		return nil
	end
	def name
		@nameSet.to_a.join("-")
	end
	def alt
		if @nameSet.include? "alt"
			return nil
		end
		altNameSet = @nameSet.dup
		altNameSet.add "alt"
		return List[altNameSet]
	end
end

def initialize_keyname_to_keyseq_data
	d = File.expand_path(__dir__)
	File.open File.expand_path("#{d}/keymap.data") do |f|
		f.each_line do |line|
			if line !~ /^(\s+|#)/
				arr = line.split
				keyname = arr[0]
				keyseq = arr[1]
				Key.emerge(name: keyname, seq: keyseq)
			end
		end
	end
end

